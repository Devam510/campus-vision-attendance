# ─── AI Attendance System v5 ─ Environment Variables Template ──────────────
# Copy this file to .env and fill in your values.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://attendance:password@localhost:5432/attendance_db

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=./credentials.json
SHEETS_REFRESH_INTERVAL_MINUTES=30

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Camera / Engine ──────────────────────────────────────────────────────────
USE_GPU=false
PROCESS_WIDTH=480
FRAME_SKIP=1

# ── YOLO ─────────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.45

# ── InsightFace ──────────────────────────────────────────────────────────────
INSIGHTFACE_MODEL_PACK=buffalo_sc
MODELS_PATH=./models

# ── Recognition ──────────────────────────────────────────────────────────────
MATCH_THRESHOLD=0.50
CONFIRM_FRAMES=3
